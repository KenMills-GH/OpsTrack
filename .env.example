PORT=5000

# Option A: single connection string (recommended for Render + Neon)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DB_SSL=true

# Option B: split connection settings
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=opstrack_db
DB_PASSWORD=replace_with_secure_password
DB_PORT=5432

JWT_SECRET=replace_with_32_plus_char_random_secret
CORS_ORIGIN=http://localhost:5173

NODE_ENV=development
